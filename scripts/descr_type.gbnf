# GBNF grammar for the set-theoretic (Descr) type syntax the model must emit.
# Used with transformers-cfg for grammar-constrained decoding: generation can ONLY
# produce well-formed, descr-only types (balanced delimiters, terminated atoms, a
# valid stop point, and no drift into TypeSpec forms like String.t()/any()/boolean()).
#
# GBNF (llama.cpp style), start symbol = root. Faithful port of descr_type.lark.
# Precedence, loosest to tightest:  or / |  <  and  <  not  <  primary

root ::= ws type ws

type ::= union
union ::= intersection (ws ("or" | "|") ws intersection)*
intersection ::= negation (ws "and" ws negation)*
negation ::= "not" ws negation | primary

primary ::= base | dynamic | funtype | list | nonemptylist | tuple | map | atomlit | "(" ws type ws ")"

base ::= "none()" | "term()" | "pid()" | "port()" | "reference()" | "integer()" | "float()" | "atom()" | "binary()" | "bitstring()" | "bitstring_no_binary()" | "empty_list()" | "fun()" | "open_map()"

dynamic ::= "dynamic(" ws (type ws)? ")"

funtype ::= "(" ws (arglist ws)? "->" ws type ws ")"
arglist ::= type (ws "," ws type)*

list ::= "[]" | "[" ws type ws "]" | "[" ws type ws "," ws "..." ws "]"
nonemptylist ::= "non_empty_list(" ws type (ws "," ws type)? ws ")"

tuple ::= "{" ws tupleitems? ws "}" | "tuple(" ws tupleitems? ws ")"
tupleitems ::= type (ws "," ws type)*

map ::= "%{" ws mapbody? ws "}"
mapbody ::= "..." (ws "," ws pairs)? | pairs
pairs ::= pair (ws "," ws pair)*
pair ::= key ws "=>" ws value
key ::= type
value ::= "if_set(" ws type ws ")" | type

atomlit ::= atom | quotedatom | "nil" | "true" | "false"
atom ::= ":" [a-zA-Z_] [a-zA-Z0-9_]* [?!]?
quotedatom ::= ":\"" [^"]* "\""

ws ::= [ \t\n]*
